# ========================
# Firebase Configuration
# ========================
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (servidor)
FIREBASE_PRIVATE_KEY=your_private_key_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ========================
# PAGHIPER Configuration
# ========================
PAGHIPER_API_KEY=your_api_key_here
PAGHIPER_TOKEN=your_token_here
PAGHIPER_WEBHOOK_SECRET=your_webhook_secret_here
PAGHIPER_PIX_URL=https://pix.paghiper.com/invoice/create/
PAGHIPER_BOLETO_URL=https://boleto.paghiper.com/invoice/create/
PAGHIPER_WEBHOOK_URL=https://your-domain.com/api/payments/webhook

# ========================
# CORS Configuration
# ========================
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ========================
# Groq AI Configuration
# ========================
GROQ_API_KEY=your_groq_api_key_here

# ========================
# Security Keys
# ========================
ADMIN_KEY=your_secret_admin_key_here
