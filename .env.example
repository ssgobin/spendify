# ========================
# Spendify - Environment Variables
# ========================
# ATENÇÃO: Este é apenas um arquivo de exemplo.
# NUNCA commite o arquivo .env com valores reais!

# ========================
# Firebase Admin SDK (Backend Only)
# ========================
# Estas credenciais são CRÍTICAS e devem ser mantidas em segredo
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ========================
# PAGHIPER Payment Gateway
# ========================
PAGHIPER_API_KEY=your_paghiper_api_key
PAGHIPER_TOKEN=your_paghiper_token
PAGHIPER_WEBHOOK_SECRET=your_webhook_secret_minimum_32_chars_long
PAGHIPER_PIX_URL=https://pix.paghiper.com/invoice/create/
PAGHIPER_BOLETO_URL=https://boleto.paghiper.com/invoice/create/
PAGHIPER_WEBHOOK_URL=https://your-domain.com/api/payments/webhook

# ========================
# CORS Configuration
# ========================
# Lista de origens permitidas separadas por vírgula
# Em desenvolvimento: http://localhost:3000,http://127.0.0.1:3000
# Em produção: https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=https://your-domain.com

# ========================
# Groq AI Configuration
# ========================
GROQ_API_KEY=your_groq_api_key_here

# ========================
# Security Configuration
# ========================
# Chave de administração para operações críticas
ADMIN_KEY=use_a_strong_random_key_here_minimum_32_characters

# Ambiente (development, production)
NODE_ENV=production

# ========================
# Rate Limiting
# ========================
# Configurações opcionais para ajustar rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
PAYMENT_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_MAX=50
